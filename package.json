{
  "name": "cf-kimi-api-ts",
  "version": "1.2.0",
  "private": true,
  "description": "Multi-model AI API gateway on Cloudflare Workers — converts Kimi Web protocol to OpenAI-compatible /v1/* endpoints with account pool, routing, and admin dashboard",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --remote",
    "deploy": "wrangler deploy",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cloudflare-workers",
    "ai-gateway",
    "kimi",
    "openai-api",
    "proxy",
    "hono"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Aleeyoo/cf-kimi-api-ts.git"
  },
  "bugs": {
    "url": "https://github.com/Aleeyoo/cf-kimi-api-ts/issues"
  },
  "homepage": "https://github.com/Aleeyoo/cf-kimi-api-ts#readme",
  "author": "chopper1026",
  "license": "MIT",
  "dependencies": {
    "hono": "^4.7.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.202412.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.92.0"
  }
}
