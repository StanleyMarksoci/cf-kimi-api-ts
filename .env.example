# Worker environment variables (local dev only)
# For production, use `wrangler secret put` instead

# Admin panel password (required)
ADMIN_PASSWORD=your_admin_password

# Cookie signing secret (recommended)
SESSION_SECRET=your_random_session_secret

# Initial Kimi token (optional)
KIMI_TOKEN=your_kimi_refresh_token_or_jwt

# Default API key for this proxy (optional)
OPENAI_API_KEY=sk-your_proxy_api_key

# Set to false for local HTTP dev
SECURE_COOKIES=false
