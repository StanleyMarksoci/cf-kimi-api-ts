# wrangler.toml.example
# Copy this to wrangler.toml and fill in your actual IDs for local development.
# For one-click deploy via deploy.workers.cloudflare.com, the wrangler.toml
# in the repo intentionally uses placeholder IDs so the tool prompts you
# to select existing resources.
#
# Fork this repo first, then deploy via:
#   https://deploy.workers.cloudflare.com/?url=https://github.com/你的用户名/cf-kimi-api-ts

name = "cf-kimi-api-ts"
main = "src/index.ts"
compatibility_date = "2024-12-01"
compatibility_flags = ["nodejs_compat"]

[assets]
directory = "static"
not_found_handling = "none"

[[kv_namespaces]]
binding = "KV"
# Replace with your KV namespace ID from Cloudflare Dashboard
id = "YOUR_KV_NAMESPACE_ID"

[[d1_databases]]
binding = "DB"
database_name = "cf-kimi-api-logs"
# Replace with your D1 database ID from Cloudflare Dashboard
database_id = "YOUR_D1_DATABASE_ID"

[vars]
KIMI_API_BASE = "https://www.kimi.com"
DEFAULT_MODEL = ""
TIMEZONE = "Asia/Shanghai"
REQUEST_LOG_RETENTION = "1000"
