name = "cf-kimi-api-ts"
main = "src/index.ts"
compatibility_date = "2024-12-01"
compatibility_flags = ["nodejs_compat"]

[assets]
directory = "static"
not_found_handling = "none"

[[kv_namespaces]]
binding = "KV"
# Replace with your KV namespace ID from Cloudflare Dashboard
id = "YOUR_KV_NAMESPACE_ID"

[[d1_databases]]
binding = "DB"
database_name = "cf-kimi-api-logs"
# Replace with your D1 database ID from Cloudflare Dashboard
database_id = "YOUR_D1_DATABASE_ID"

[vars]
KIMI_API_BASE = "https://www.kimi.com"
DEFAULT_MODEL = ""
TIMEZONE = "Asia/Shanghai"
REQUEST_LOG_RETENTION = "1000"
